{
  "expo": {
    "name": "Kostenkompass",
    "slug": "kostenkompass-mobile",
    "version": "0.2.0",
    "orientation": "portrait",
    "scheme": "kostenkompass",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "de.h3nri5h.kostenkompass"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "de.h3nri5h.kostenkompass"
    },
    "web": {
      "output": "static"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
